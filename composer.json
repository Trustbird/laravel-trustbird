{
  "name": "trustbird/laravel-trustbird",
  "description": "Open core Laravel package for building a self-hosted Trustbird ISMS.",
  "type": "library",
  "license": "AGPL-3.0-only",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^12.0|^13.0",
    "illuminate/database": "^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0|^11.0",
    "pestphp/pest": "^3.0|^4.0",
    "pestphp/pest-plugin-laravel": "^3.0|^4.0"
  },
  "autoload": {
    "psr-4": {
      "Trustbird\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Trustbird\\Tests\\": "tests/",
      "Trustbird\\Database\\Factories\\": "database/factories/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Trustbird\\TrustbirdServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "pest",
    "test:coverage": "pest --coverage --min=100"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
