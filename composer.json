{
  "name": "trustbird/laravel-trustbird",
  "description": "Open core Laravel package for building a self-hosted Trustbird ISMS.",
  "keywords": [
    "trustbird",
    "isms",
    "iso27001",
    "nis2",
    "compliance",
    "laravel"
  ],
  "homepage": "https://trustbird.com",
  "license": "AGPL-3.0-only",
  "type": "library",
  "require": {
    "php": "^8.3",
    "illuminate/support": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "Trustbird\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Trustbird\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Trustbird\\TrustbirdServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}